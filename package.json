{
    "name": "questlog-mcp",
    "version": "0.1.2",
    "description": "An MCP server for Taskwarrior task management.",
    "keywords": [
        "mcp",
        "task-management",
        "taskwarrior"
    ],
    "license": "MIT",
    "author": "Joey McKenzie",
    "bin": {
        "taskwarrior-mcp": "./dist/index.js"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "type": "module",
    "main": "./dist/index.js",
    "scripts": {
        "build": "bun build ./index.ts --outfile ./dist/index.js --target node --banner '#!/usr/bin/env node' && chmod +x ./dist/index.js",
        "prepublishOnly": "bun run build",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "types": "tsc",
        "types:check": "tsc --noEmit",
        "check": "bun lint && bun fmt:check && bun types:check",
        "prepare": "husky"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "effect": "^3.19.19",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^16.3.2",
        "oxfmt": "^0.36.0",
        "oxlint": "^1.51.0",
        "typescript": "5.9"
    },
    "lint-staged": {
        "*.{json,md}": "bun fmt",
        "*.{js,ts}": [
            "bun fmt",
            "bun lint:fix"
        ]
    }
}

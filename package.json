{
    "name": "taskwarrior-mcp",
    "private": true,
    "type": "module",
    "module": "index.ts",
    "scripts": {
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "types": "tsc",
        "types:check": "tsc --noEmit",
        "check": "bun lint && bun fmt:check && bun types:check",
        "prepare": "husky"
    },
    "dependencies": {
        "@effect/platform": "^0.94.5",
        "@effect/platform-bun": "^0.87.1",
        "@modelcontextprotocol/sdk": "^1.27.1",
        "effect": "^3.19.19",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.2",
        "oxfmt": "^0.36.0",
        "oxlint": "^1.51.0"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    },
    "lint-staged": {
        "*.{json,md}": "bun fmt",
        "*.{js,ts}": [
            "bun fmt",
            "bun lint:fix"
        ]
    }
}
